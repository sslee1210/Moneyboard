# Moneyboard local-only KIS Open API configuration
# 1) Copy this file to .env
# 2) Fill in your Korea Investment & Securities Open API values
# 3) Run: npm run server

# true로 바꾸고 APP_KEY/APP_SECRET을 입력해야 KIS가 켜집니다.
KIS_ENABLED=false

# real: 실전투자 / demo: 모의투자
KIS_ENV=real

# 한국투자증권 Open API 앱키/앱시크릿
KIS_APP_KEY=
KIS_APP_SECRET=

# 현재가 조회만 할 경우 계좌번호는 필수는 아니지만, 이후 주문/잔고 기능 확장 대비 입력 가능
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=

# J: KRX / NX: NXT / UN: 통합
KIS_MARKET_DIV_CODE=J

# 로컬 자동 갱신/호출 제한 보호 설정
STREAM_PUSH_MS=1000
MARKET_CACHE_MS=1000
DETAIL_CACHE_MS=3000
KIS_QUOTE_CACHE_MS=15000
KIS_STOCK_CONCURRENCY=2
KIS_MARKET_VERIFY_TOP_SECTORS=12
KIS_MARKET_VERIFY_TOP_STOCKS=8
KIS_SELECTED_SECTOR_STOCKS=20
