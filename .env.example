PORT=4173
MARKET_CACHE_MS=30000
VOLUME_HISTORY_LIMIT=12

PRECISION_WATCH_LIMIT=40
PRECISION_SOURCE_TOP_SECTORS=12
PRECISION_MIN_TRADE_AMOUNT_MILLION=0
PRECISION_API_ENABLED=false
PRECISION_API_PROVIDER=kiwoom
PRECISION_MARKET_SCOPE=KRX_SELECTED

# Kiwoom OpenAPI+ is a Windows local program/COM style API.
# Moneyboard should connect through a local bridge process, not directly through browser JavaScript.
KIWOOM_ENABLED=false
KIWOOM_MODE=real
KIWOOM_BRIDGE_URL=http://127.0.0.1:8765
KIWOOM_BRIDGE_TOKEN=
KIWOOM_ACCOUNT_NO=
KIWOOM_WATCH_LIMIT=40
KIWOOM_SCREEN_NO=9000
KIWOOM_REAL_FIDS=10;13;14;15;20;228
KIWOOM_HEALTH_PATH=/health
KIWOOM_STREAM_PATH=/stream
KIWOOM_REGISTER_PATH=/register
KIWOOM_TIMEOUT_MS=5000

# Optional legacy KIS settings. Keep disabled when using Kiwoom.
KIS_ENABLED=false
KIS_MODE=mock
KIS_APP_KEY=
KIS_APP_SEC=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_REST_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_WS_URL=
KIS_APPROVAL_KEY=
KIS_TIMEOUT_MS=7000

KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_MOCK=true
KIS_DETAIL_QUOTE_LIMIT=20
KIS_QUOTE_CONCURRENCY=4
KIS_VOLUME_HISTORY_LIMIT=12

VITE_API_BASE_URL=
