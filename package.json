{
  "name": "moneyboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "node scripts/ensure-dist.mjs && node scripts/run-practical-server.mjs",
    "server:build": "vite build && node scripts/run-practical-server.mjs",
    "server:raw": "node server.js",
    "server:sanitized": "node server-local.js",
    "server:practical": "node server-practical.js",
    "server:focus40": "node server-focus40.js",
    "snapshot": "node scripts/generate-static-data.mjs",
    "validate:data": "node scripts/generate-static-data.mjs",
    "test": "node scripts/test-core.mjs && npm run build",
    "test:core": "node scripts/test-core.mjs",
    "test:live": "node scripts/test-live.mjs",
    "test:local": "node scripts/test-local.mjs",
    "build": "vite build",
    "build:static": "npm run snapshot && vite build",
    "build:pages": "npm run snapshot && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "npm run server"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "cheerio": "^1.1.2",
    "express": "^5.1.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.3.0",
    "vite": "^8.0.16"
  }
}
