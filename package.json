{
  "name": "moneyboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "set STREAM_PUSH_MS=2000&& set MARKET_CACHE_MS=10000&& set DETAIL_CACHE_MS=30000&& set DETAIL_CONCURRENCY=8&& set KIS_MARKET_VERIFY_TOP_SECTORS=0&& set KIS_MARKET_VERIFY_TOP_STOCKS=0&& set KIS_REALTIME_SCOPE=all&& set KIS_REALTIME_MAX_CODES=5000&& set KIS_REALTIME_TOP_SECTORS=999&& set KIS_REALTIME_TOP_STOCKS=999&& node server-local.js",
    "server:raw": "node server.js",
    "snapshot": "node scripts/generate-static-data.mjs",
    "validate:data": "node scripts/generate-static-data.mjs",
    "test": "node scripts/test-core.mjs && npm run build",
    "test:core": "node scripts/test-core.mjs",
    "test:live": "node scripts/test-live.mjs",
    "test:local": "node scripts/test-local.mjs",
    "build": "vite build",
    "build:static": "npm run snapshot && vite build",
    "build:pages": "npm run snapshot && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "npm run build && node server-local.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "cheerio": "^1.1.2",
    "express": "^5.1.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.3.0",
    "vite": "^8.0.16"
  }
}
